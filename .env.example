# Required: API key for The Odds API
ODDS_API_KEY=

# Optional: override upstream base URL (default: https://api.the-odds-api.com)
ODDS_API_BASE=https://api.the-odds-api.com

# Optional: edge cache directives for API responses
EDGE_CACHE_S_MAXAGE=30
EDGE_CACHE_SWR=120

# Cache provider config (optional, recommended in production)
CACHE_PROVIDER=redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: override sharp book list/weights tuning in code
SHARP_BOOKS=pinnacle,circa,betcris
